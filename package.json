{
  "name": "pianolab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PianoLab — aplicación web open-source para aprender piano con teoría interactiva, validación por micrófono, digitación y repertorio de práctica.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^24.2.1",
    "pitchy": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "tone": "^15.0.4",
    "vexflow": "^4.2.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
